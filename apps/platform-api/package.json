    "@fastify/cookie": "10.0.1",
    "@fastify/cors": "10.0.1",
    "@fastify/jwt": "9.0.0",
    "@fastify/rate-limit": "10.1.1",
    "@google-cloud/storage": "7.17.2",
    "bcryptjs": "2.4.3",
    "drizzle-orm": "0.39.2",
    "fastify": "5.2.1",
    "pg": "8.13.3",
    "pino": "9.6.0",
    "prom-client": "15.1.3",
    "ws": "8.18.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "10.16.0",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.13.5",
    "@types/pg": "8.11.11",
    "@types/ws": "8.5.14",
    "supertest": "7.0.0",
    "testcontainers": "10.16.0",
    "tsx": "4.19.2",
