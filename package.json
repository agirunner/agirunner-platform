{
  "name": "agentbaton-platform",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.6.1",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test && pnpm test:harness",
    "test:harness": "tsx --test tests/live/harness/*.test.ts",
    "test:ci": "pnpm test:reports:enforce && pnpm test:definitions:validate && pnpm test && pnpm test:core",
    "test:core": "tsx tests/live/harness/runner.ts --lane core",
    "test:core:all": "tsx tests/live/harness/runner.ts --lane core --all",
    "test:live": "tsx tests/live/harness/runner.ts --lane live",
    "test:live:all": "tsx tests/live/harness/runner.ts --lane live --all",
    "test:live:quick": "tsx tests/live/harness/runner.ts --lane live --happy-only --provider openai",
    "test:traceability:reset": "tsx tests/live/harness/traceability-flow.ts reset",
    "test:traceability:run": "tsx tests/live/harness/traceability-flow.ts run",
    "test:reports:enforce": "tsx tests/live/harness/enforce-report-layout.ts",
    "test:definitions:validate": "pnpm test:reports:enforce && tsx tests/live/harness/validate-test-case-definitions.ts",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@playwright/test": "1.50.1",
    "@types/bcryptjs": "2.4.6",
    "@types/node": "22.13.5",
    "@types/pg": "8.11.11",
    "@typescript-eslint/eslint-plugin": "8.24.0",
    "@typescript-eslint/parser": "8.24.0",
    "bcryptjs": "2.4.3",
    "eslint": "9.20.1",
    "eslint-config-prettier": "10.0.1",
    "pg": "8.13.3",
    "prettier": "3.5.2",
    "tsx": "4.19.2",
    "turbo": "2.4.2",
    "typescript": "5.7.3"
  }
}
