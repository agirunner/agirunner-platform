# -----------------------------------------------------------------------------
# Required startup secrets
# -----------------------------------------------------------------------------
JWT_SECRET=replace-with-at-least-32-characters
WEBHOOK_ENCRYPTION_KEY=replace-with-at-least-32-characters

# Shared bootstrap admin key for full docker-compose stack.
# Must start with "ab_admin_def" so it matches first-boot seed semantics.
# platform-api uses this only to seed the first human/admin login path.
DEFAULT_ADMIN_API_KEY=ab_admin_defreplace-with-at-least-20-characters

# Service key used by container-manager and other internal stack-to-platform calls.
# Must use the canonical ar_service_<secret> format so the platform can seed it
# as the default service credential on first boot.
# Example local key: PLATFORM_SERVICE_API_KEY=ar_service_replace-with-at-least-20-characters
PLATFORM_SERVICE_API_KEY=ar_service_replace-with-at-least-20-characters

# -----------------------------------------------------------------------------
# Platform / database overrides
# -----------------------------------------------------------------------------
NODE_ENV=production
POSTGRES_DB=agirunner
POSTGRES_USER=agirunner
POSTGRES_PASSWORD=agirunner
POSTGRES_PORT=5432
PLATFORM_API_PORT=8080
DASHBOARD_PORT=3000
CORS_ORIGIN=http://localhost:3000
VITE_PLATFORM_API_URL=http://localhost:8080
LOG_LEVEL=info
EVENT_STREAM_PATH=/api/v1/events/stream
JWT_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=30d
COMMUNITY_CATALOG_REPOSITORY=agirunner/agirunner-playbooks
COMMUNITY_CATALOG_REF=main
COMMUNITY_CATALOG_RAW_BASE_URL=https://raw.githubusercontent.com
# Optional: point platform-api at a locally mounted community catalog checkout.
# COMMUNITY_CATALOG_LOCAL_ROOT=/community-catalog-source
# COMMUNITY_CATALOG_LOCAL_HOST_ROOT=../agirunner-playbooks

# Bootstrap runtime image used when the container manager and first-boot seed data
# still need an initial image value. Like DEFAULT_ADMIN_API_KEY, this is only the
# starting point: operators can change or rotate runtime images later from the
# dashboard or API without editing .env again.
# If this is omitted entirely, bootstrap falls back to agirunner-runtime:local.
# Example local tag: RUNTIME_IMAGE=agirunner-runtime:local
# Example published tag: RUNTIME_IMAGE=ghcr.io/agirunner/agirunner-runtime:latest
# Example pinned digest: RUNTIME_IMAGE=ghcr.io/agirunner/agirunner-runtime@sha256:<digest>
RUNTIME_IMAGE=agirunner-runtime:local

# LLM provider credentials are configured via the dashboard (Config > LLM Providers).
# No API keys needed in .env — add providers through the admin UI after first boot.

# -----------------------------------------------------------------------------
# OAuth provider authentication (optional — needed only for OAuth LLM providers)
# -----------------------------------------------------------------------------
# Base URL for OAuth redirect callbacks (must match your external dashboard URL).
# Example: https://agirunner.example.com or http://localhost:8080
OAUTH_REDIRECT_BASE_URL=http://localhost:8080
