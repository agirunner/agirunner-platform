# -----------------------------------------------------------------------------
# Required startup secrets
# -----------------------------------------------------------------------------
# Prefer secret files in production. The compose stack mounts ./.secrets at
# /run/secrets and uses *_FILE bindings by default.
JWT_SECRET=replace-with-at-least-32-characters
WEBHOOK_ENCRYPTION_KEY=replace-with-at-least-32-characters

# Shared bootstrap admin key for full docker-compose stack.
# Must start with "ab_admin_def" so it matches first-boot seed semantics.
# platform-api uses this as DEFAULT_ADMIN_API_KEY and worker uses it as PLATFORM_API_KEY.
DEFAULT_ADMIN_API_KEY=ab_admin_defreplace-with-at-least-20-characters

# -----------------------------------------------------------------------------
# Optional platform/database overrides
# -----------------------------------------------------------------------------
NODE_ENV=production
POSTGRES_DB=agentbaton
POSTGRES_USER=agentbaton
POSTGRES_PASSWORD=agentbaton
POSTGRES_PORT=5432
PLATFORM_API_PORT=8080
DASHBOARD_PORT=3000
CORS_ORIGIN=http://localhost:3000
VITE_PLATFORM_API_URL=http://localhost:8080
LOG_LEVEL=info
EXECUTE_ROUTE_MODE=disabled
EVENT_STREAM_PATH=/api/v1/events/stream
JWT_EXPIRES_IN=12h
JWT_REFRESH_EXPIRES_IN=30d

# -----------------------------------------------------------------------------
# Live test harness controls
# -----------------------------------------------------------------------------
# When true, live harness setup skips `docker compose up` and only performs
# health checks. Use this when the stack lifecycle is managed externally.
LIVE_SKIP_STACK_SETUP=false

# When true, force `docker compose up --build` even if harness fingerprint says
# image inputs are unchanged. Useful for baseline benchmarking and cache busts.
LIVE_FORCE_DOCKER_BUILD=false

# -----------------------------------------------------------------------------
# Internal runtime + worker topology (docker-compose defaults)
# -----------------------------------------------------------------------------
# Default local runtime image tag built from ../agentbaton-runtime.
# For staging/release set this to a digest-pinned runtime image reference
# (e.g. registry.github.com/enterprise-private/agentbaton-runtime@sha256:...).
AGENTBATON_RUNTIME_IMAGE=agentbaton-runtime:local
AGENTBATON_TASK_IMAGE=alpine/git:2.47.2

# Socket-proxy path expectation for runtime daemon access (FR-RT-741 / RT-14).
RUNTIME_DOCKER_HOST=tcp://socket-proxy:2375
RUNTIME_ENFORCE_SOCKET_PROXY=true

# Runtime-compat is test-only and should be enabled only with docker-compose.test.yml.
# `prod`: runtime auth + AGENT_API_URL bridge required.
# `test`: deterministic fallback allowed only when explicitly enabled below.
RUNTIME_COMPAT_PROFILE=test
RUNTIME_COMPAT_ENABLE_DETERMINISTIC_FALLBACK=false

# The compose stack runs five dedicated worker/runtime pairs by default:
# project-manager, architect, developer, reviewer, qa.
# These legacy single-worker variables remain useful for ad hoc worker-process
# runs outside compose, but the compose topology now sets per-role values inline.
WORKER_NAME=internal-worker
WORKER_CAPS=llm-api,role:architect,role:developer,role:reviewer,role:qa,lang:typescript,lang:python,lang:go
WORKER_HB_SECS=30
TASK_TIMEOUT_MS=300000

# Internal worker backend defaults to go-runtime in v1.05 S3.
# Set INTERNAL_WORKER_BACKEND=legacy-node only for explicit rollback drills.
INTERNAL_WORKER_BACKEND=go-runtime
RUNTIME_URL=http://internal-runtime:8081/api/v1/tasks
# Required in default/prod runtime profile. Set to a unique secret (>=20 chars); no default is provided.
RUNTIME_API_KEY=

# Executor bridge URL used only by docker-compose.test.yml runtime-compat lanes.
AGENT_API_URL=http://host.docker.internal:8080/execute
AGENT_API_KEY=

# Optional LLM provider selection for built-in worker role execution
BUILT_IN_WORKER_LLM_PROVIDER=openai

# Provider credentials (set only what you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Optional file-backed secret paths for production stacks
# -----------------------------------------------------------------------------
# These are consumed inside containers; local compose mounts ./.secrets to
# /run/secrets and wires the container env vars automatically.
JWT_SECRET_FILE=/run/secrets/jwt_secret
WEBHOOK_ENCRYPTION_KEY_FILE=/run/secrets/webhook_encryption_key
DEFAULT_ADMIN_API_KEY_FILE=/run/secrets/default_admin_api_key
RUNTIME_API_KEY_FILE=/run/secrets/runtime_api_key
AGENT_API_KEY_FILE=/run/secrets/agent_api_key
OPENAI_API_KEY_FILE=/run/secrets/openai_api_key

# ----------------------------------------------------------------------------
# Hybrid output-authenticity gate (phase 1)
# ----------------------------------------------------------------------------
# Evaluator LLM settings for non-deterministic scenarios (default: OpenAI gpt-4o-mini).
LIVE_AUTH_LLM_PROVIDER=openai
LIVE_AUTH_LLM_MODEL=gpt-4o-mini
LIVE_AUTH_LLM_TIMEOUT_MS=20000
LIVE_AUTH_LLM_API_BASE_URL=https://api.openai.com/v1
LIVE_AUTH_LLM_MAX_EVIDENCE_CHARS=1200
