# Copy to .env.test-batch (or export in shell) before running pnpm test:batch.
# Required provider keys (set for providers you plan to run):
OPENAI_API_KEY=your-openai-key
ANTHROPIC_API_KEY=your-anthropic-key
GOOGLE_API_KEY=your-google-ai-studio-key
# Optional alias accepted by harness for google provider:
GEMINI_API_KEY=

# Live authenticity validator defaults (override as needed):
LIVE_AUTH_LLM_PROVIDER=openai
LIVE_AUTH_LLM_MODEL=gpt-4o-mini
LIVE_AUTH_LLM_API_BASE_URL=https://api.openai.com/v1
LIVE_AUTH_LLM_TIMEOUT_MS=20000
LIVE_AUTH_LLM_MAX_EVIDENCE_CHARS=1200

# Optional evaluation mode override:
LIVE_EVALUATION_MODE=deterministic
LIVE_EVALUATION_PROVIDER=
LIVE_EVALUATION_MODEL=

# Live harness worker bootstrap configuration:
# AGENT_API_URL/AGENT_API_KEY may be required for AP scenarios depending on environment.
AGENT_API_URL=
AGENT_API_KEY=
DEFAULT_ADMIN_API_KEY=ab_admin_def_replace_with_stable_key

# Optional compose/runtime overrides:
JWT_SECRET=replace-with-at-least-32-char-secret
WEBHOOK_ENCRYPTION_KEY=replace-with-at-least-32-char-secret
BUILT_IN_WORKER_LLM_PROVIDER=openai
LIVE_COMPOSE_MIN_FREE_GB=10

# Optional batch-runner controls:
# BATCH_PARALLEL_MAX=3
# BATCH_LOG_TAIL_LINES=40
