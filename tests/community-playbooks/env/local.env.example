# Optional suite-local overrides loaded after tests/live/env/local.env.
# Keep the shared live-test baseline in tests/live/env/local.env and use this file
# only for community-playbooks-specific overrides.
#
# You can point the runner at a different override file with:
#   COMMUNITY_PLAYBOOKS_ENV_FILE=/path/to/local.env

# Optional result/output override.
# COMMUNITY_PLAYBOOKS_RESULTS_DIR=tests/community-playbooks/results

# Optional dashboard override for manual operator passes.
# DASHBOARD_PORT=3000

# Optional local playbooks checkout override. The suite prefers a local
# agirunner-playbooks repo and clears any inherited COMMUNITY_CATALOG_REF
# override when that checkout exists.
# PLAYBOOKS_REPO_PATH=/absolute/path/to/agirunner-playbooks

# Optional deterministic remote MCP fixture override.
# LIVE_TEST_REMOTE_MCP_FIXTURE_PARAMETERIZED_SECRET=live-test-parameterized-secret

# Optional provider-selection aliases used by:
#   bash tests/community-playbooks/run.sh --provider <anthropic|gemini|openai-api|openai-oauth>
# LIVE_TEST_ANTHROPIC_API_KEY=replace-me
# LIVE_TEST_GEMINI_API_KEY=replace-me
# LIVE_TEST_OPENAI_API_KEY=replace-me
# LIVE_TEST_OPENAI_OAUTH_PROFILE_ID=openai-codex
# LIVE_TEST_OPENAI_OAUTH_SESSION_JSON='{"credentials":{"accessToken":"replace-me","refreshToken":"replace-me"}}'
