# Shared platform secrets. These must match the values injected into the local compose stack.
DEFAULT_ADMIN_API_KEY=replace-me
PLATFORM_SERVICE_API_KEY=ar_service_replace-me
JWT_SECRET=replace-me
WEBHOOK_ENCRYPTION_KEY=replace-me

# Live-model provider selection.
# Use one auth mode at a time:
# - oauth: recommended when you have a browser-backed provider session snapshot
# - api_key: recommended for direct provider API keys
LIVE_TEST_PROVIDER_AUTH_MODE=oauth

# Provider identity and base URL.
# OpenAI OAuth example:
LIVE_TEST_PROVIDER_TYPE=openai
LIVE_TEST_PROVIDER_NAME=OpenAI (Subscription)
LIVE_TEST_PROVIDER_BASE_URL=https://chatgpt.com/backend-api

# OAuth mode requires a provider profile id and an env-owned session snapshot.
LIVE_TEST_PROVIDER_OAUTH_PROFILE_ID=openai-codex
LIVE_TEST_PROVIDER_OAUTH_SESSION_JSON='{"credentials":{"accessToken":"replace-me","refreshToken":"replace-me","authorizedAt":"2026-03-21T00:00:00.000Z"}}'

# API-key mode uses the same generic provider fields above plus LIVE_TEST_PROVIDER_API_KEY.
# Example Anthropic API-key configuration:
# LIVE_TEST_PROVIDER_AUTH_MODE=api_key
# LIVE_TEST_PROVIDER_TYPE=anthropic
# LIVE_TEST_PROVIDER_NAME=Anthropic
# LIVE_TEST_PROVIDER_BASE_URL=https://api.anthropic.com
# LIVE_TEST_PROVIDER_API_KEY=replace-me
#
# Example Gemini API-key configuration:
# LIVE_TEST_PROVIDER_AUTH_MODE=api_key
# LIVE_TEST_PROVIDER_TYPE=google
# LIVE_TEST_PROVIDER_NAME=Gemini
# LIVE_TEST_PROVIDER_BASE_URL=https://generativelanguage.googleapis.com
# LIVE_TEST_PROVIDER_API_KEY=replace-me

# Shared model defaults.
LIVE_TEST_MODEL_ID=gpt-5.4
LIVE_TEST_MODEL_ENDPOINT_TYPE=responses
LIVE_TEST_SYSTEM_REASONING_EFFORT=medium
LIVE_TEST_ORCHESTRATOR_MODEL_ID=gpt-5.4
LIVE_TEST_ORCHESTRATOR_REASONING_EFFORT=low
LIVE_TEST_SPECIALIST_MODEL_ID=gpt-5.4
LIVE_TEST_SPECIALIST_REASONING_EFFORT=medium

# Git-backed workspace scenarios still need repository push access.
LIVE_TEST_GIT_TOKEN=replace-me
LIVE_TEST_GIT_USER_NAME="Agirunner Live Tests"
LIVE_TEST_GIT_USER_EMAIL=live-tests@example.invalid

# Git-backed workspace scenarios use the sibling fixtures clone by default.
# Override these only if your local setup differs.
# FIXTURES_REPO_PATH=/absolute/path/to/agirunner-test-fixtures
# LIVE_TEST_FIXTURES_REMOTE_NAME=origin
# LIVE_TEST_REPOSITORY_URL=https://github.com/your-org/your-test-fixtures.git
# LIVE_TEST_DEFAULT_BRANCH=main
# LIVE_TEST_RUN_BRANCH_PREFIX=live-test

# Optional local fixture overrides. Leave these alone unless you need to change the deterministic local MCP fixture.
# LIVE_TEST_REMOTE_MCP_FIXTURE_PORT=18080
# LIVE_TEST_REMOTE_MCP_FIXTURE_PARAMETERIZED_SECRET=live-test-parameterized-secret

# Optional local-only provider snapshots for deterministic `--provider` switching in
# `tests/community-playbooks/run.sh`. Keep them commented out in the shared env file
# and let the runner read them only when you pass an explicit provider selection.
# BEGIN LOCAL PROVIDER SNAPSHOTS
# Anthropic API
# LIVE_TEST_PROVIDER_AUTH_MODE=api_key
# LIVE_TEST_PROVIDER_TYPE=anthropic
# LIVE_TEST_PROVIDER_NAME=Anthropic
# LIVE_TEST_PROVIDER_BASE_URL=https://api.anthropic.com
# LIVE_TEST_MODEL_ID=claude-sonnet-4-6
# LIVE_TEST_MODEL_ENDPOINT_TYPE=messages
# LIVE_TEST_ORCHESTRATOR_MODEL_ID=claude-sonnet-4-6
# LIVE_TEST_ORCHESTRATOR_MODEL_ENDPOINT_TYPE=messages
# LIVE_TEST_SPECIALIST_MODEL_ID=claude-sonnet-4-6
# LIVE_TEST_SPECIALIST_MODEL_ENDPOINT_TYPE=messages
# LIVE_TEST_PROVIDER_API_KEY=replace-me
# LIVE_TEST_ORCHESTRATOR_REASONING_EFFORT=medium
#
# Gemini API
# LIVE_TEST_PROVIDER_AUTH_MODE=api_key
# LIVE_TEST_PROVIDER_TYPE=google
# LIVE_TEST_PROVIDER_NAME=Gemini
# LIVE_TEST_PROVIDER_BASE_URL=https://generativelanguage.googleapis.com
# LIVE_TEST_MODEL_ID=gemini-3.1-pro-preview
# LIVE_TEST_MODEL_ENDPOINT_TYPE=generate-content
# LIVE_TEST_ORCHESTRATOR_MODEL_ID=gemini-3.1-pro-preview
# LIVE_TEST_ORCHESTRATOR_MODEL_ENDPOINT_TYPE=generate-content
# LIVE_TEST_SPECIALIST_MODEL_ID=gemini-3.1-pro-preview
# LIVE_TEST_SPECIALIST_MODEL_ENDPOINT_TYPE=generate-content
# LIVE_TEST_PROVIDER_API_KEY=replace-me
#
# OpenAI API
# LIVE_TEST_PROVIDER_AUTH_MODE=api_key
# LIVE_TEST_PROVIDER_TYPE=openai
# LIVE_TEST_PROVIDER_NAME=OpenAI (API Key)
# LIVE_TEST_PROVIDER_BASE_URL=https://api.openai.com/v1
# LIVE_TEST_MODEL_ID=gpt-5.4
# LIVE_TEST_MODEL_ENDPOINT_TYPE=responses
# LIVE_TEST_ORCHESTRATOR_MODEL_ID=gpt-5.4
# LIVE_TEST_ORCHESTRATOR_MODEL_ENDPOINT_TYPE=responses
# LIVE_TEST_SPECIALIST_MODEL_ID=gpt-5.4
# LIVE_TEST_SPECIALIST_MODEL_ENDPOINT_TYPE=responses
# LIVE_TEST_PROVIDER_API_KEY=replace-me
#
# OpenAI OAuth
# LIVE_TEST_PROVIDER_AUTH_MODE=oauth
# LIVE_TEST_PROVIDER_TYPE=openai
# LIVE_TEST_PROVIDER_NAME=OpenAI (Subscription)
# LIVE_TEST_PROVIDER_BASE_URL=https://chatgpt.com/backend-api
# LIVE_TEST_PROVIDER_OAUTH_PROFILE_ID=openai-codex
# LIVE_TEST_PROVIDER_OAUTH_SESSION_JSON='{"credentials":{"accessToken":"replace-me","refreshToken":"replace-me"}}'
# LIVE_TEST_MODEL_ID=gpt-5.4
# LIVE_TEST_MODEL_ENDPOINT_TYPE=responses
# LIVE_TEST_ORCHESTRATOR_MODEL_ID=gpt-5.4
# LIVE_TEST_ORCHESTRATOR_MODEL_ENDPOINT_TYPE=responses
# LIVE_TEST_SPECIALIST_MODEL_ID=gpt-5.4
# LIVE_TEST_SPECIALIST_MODEL_ENDPOINT_TYPE=responses
# END LOCAL PROVIDER SNAPSHOTS

# Optional local stack overrides if your machine cannot use the defaults below.
# POSTGRES_DB=agirunner
# POSTGRES_USER=agirunner
# POSTGRES_PASSWORD=agirunner
# POSTGRES_PORT=5432
# PLATFORM_API_PORT=8080
