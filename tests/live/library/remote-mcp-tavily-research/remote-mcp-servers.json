[
  {
    "name": "Tavily MCP",
    "description": "Remote Tavily MCP server for web search and research.",
    "endpointUrl": "https://mcp.tavily.com/mcp/",
    "authMode": "parameterized",
    "enabledByDefaultForNewSpecialists": false,
    "grantToAllExistingSpecialists": false,
    "parameters": [
      {
        "placement": "query",
        "key": "tavilyApiKey",
        "valueKind": "secret",
        "value": {
          "env": "LIVE_TEST_TAVILY_API_KEY"
        }
      }
    ]
  }
]
