{
  "name": "SDLC Required Plus Optional Assessor Pending Pipeline",
  "slug": "live-test-sdlc-required-plus-optional-assessor-pending-v1",
  "description": "Software-delivery workflow where an optional assessor remains uninstantiated or unresolved while required approval still clears the path.",
  "outcome": "Optional assessment does not block successor work when not required.",
  "lifecycle": "planned",
  "definition": {
    "process_instructions": "The required quality assessor clears the subject. The optional security assessor may remain absent or unresolved, and that must not block successor work in this scenario.",
    "parameters": [
      {
        "name": "goal",
        "type": "string",
        "required": true,
        "category": "input",
        "description": "What this live workflow should accomplish"
      },
      {
        "name": "change_request",
        "type": "string",
        "required": true,
        "category": "input",
        "description": "Concrete repository change to implement in the seeded CLI workspace"
      },
      {
        "name": "optional_assessor_contract",
        "type": "string",
        "required": true,
        "category": "input",
        "description": "When to skip or instantiate the optional assessor and what it must enforce"
      }
    ],
    "roles": [
      "opt-pending-design-architect",
      "opt-pending-delivery-engineer",
      "opt-pending-quality-assessor",
      "opt-pending-security-assessor",
      "opt-pending-release-manager"
    ],
    "board": {
      "entry_column_id": "planned",
      "columns": [
        {
          "id": "planned",
          "label": "Planned",
          "description": "Work is defined but not yet assigned."
        },
        {
          "id": "active",
          "label": "In Progress",
          "description": "A specialist is actively working."
        },
        {
          "id": "blocked",
          "label": "Blocked",
          "description": "Work is blocked and needs intervention.",
          "is_blocked": true
        },
        {
          "id": "done",
          "label": "Done",
          "description": "The work item meets its acceptance criteria.",
          "is_terminal": true
        }
      ]
    },
    "stages": [
      {
        "name": "design-brief",
        "goal": "The design is ready.",
        "involves": [
          "opt-pending-design-architect"
        ]
      },
      {
        "name": "implementation",
        "goal": "The change is implemented and assessed.",
        "involves": [
          "opt-pending-delivery-engineer",
          "opt-pending-quality-assessor",
          "opt-pending-security-assessor"
        ]
      },
      {
        "name": "release-readiness",
        "goal": "Release packaging is complete.",
        "involves": [
          "opt-pending-release-manager"
        ]
      }
    ],
    "checkpoints": [
      {
        "name": "design-brief",
        "goal": "The design is ready.",
        "human_gate": false,
        "entry_criteria": "The request is authored."
      },
      {
        "name": "implementation",
        "goal": "The change is implemented and assessed.",
        "human_gate": false,
        "entry_criteria": "The design brief exists."
      },
      {
        "name": "release-readiness",
        "goal": "Release packaging is complete.",
        "human_gate": false,
        "entry_criteria": "All required assessments are approved."
      }
    ],
    "approval_rules": [],
    "handoff_rules": [
      {
        "from_role": "opt-pending-design-architect",
        "to_role": "opt-pending-delivery-engineer",
        "required": true
      },
      {
        "from_role": "opt-pending-quality-assessor",
        "to_role": "opt-pending-release-manager",
        "required": true
      },
      {
        "from_role": "opt-pending-security-assessor",
        "to_role": "opt-pending-release-manager",
        "required": true
      }
    ],
    "lifecycle": "planned",
    "orchestrator": {
      "max_rework_iterations": 5,
      "max_active_tasks": 4,
      "max_active_tasks_per_work_item": 3,
      "allow_parallel_work_items": false
    },
    "assessment_rules": [
      {
        "subject_role": "opt-pending-delivery-engineer",
        "assessed_by": "opt-pending-quality-assessor",
        "checkpoint": "implementation",
        "required": true,
        "outcome_actions": {
          "request_changes": {
            "action": "reopen_subject"
          },
          "rejected": {
            "action": "block_subject"
          }
        }
      },
      {
        "subject_role": "opt-pending-delivery-engineer",
        "assessed_by": "opt-pending-security-assessor",
        "checkpoint": "implementation",
        "optional": true,
        "outcome_actions": {
          "request_changes": {
            "action": "escalate"
          },
          "rejected": {
            "action": "block_subject"
          }
        }
      }
    ]
  }
}
