{
  "name": "SDLC Optional Assessment Pipeline",
  "slug": "live-test-sdlc-optional-assessment-v1",
  "description": "Software-delivery pipeline with one required assessor and one optional assessor.",
  "outcome": "Required assessments always gate progress; optional assessments only gate once instantiated.",
  "lifecycle": "planned",
  "definition": {
    "process_instructions": "The solution design architect defines the change. The application delivery engineer implements it. The delivery quality assessor is always required. The security risk assessor is optional and may be skipped or instantiated based on the authored scenario contract. If the optional assessment is instantiated, its result must be respected.",
    "parameters": [
      {
        "name": "goal",
        "type": "string",
        "required": true,
        "category": "input",
        "description": "What this live workflow should accomplish"
      }
    ],
    "roles": [
      "solution-design-architect",
      "application-delivery-engineer",
      "delivery-quality-assessor",
      "security-risk-assessor",
      "change-release-manager"
    ],
    "board": {
      "entry_column_id": "planned",
      "columns": [
        {
          "id": "planned",
          "label": "Planned",
          "description": "Work is defined but not yet assigned."
        },
        {
          "id": "active",
          "label": "In Progress",
          "description": "A specialist is actively working."
        },
        {
          "id": "blocked",
          "label": "Blocked",
          "description": "Work is blocked and needs intervention.",
          "is_blocked": true
        },
        {
          "id": "done",
          "label": "Done",
          "description": "The work item meets its acceptance criteria.",
          "is_terminal": true
        }
      ]
    },
    "stages": [
      {
        "name": "design-brief",
        "goal": "The design is ready.",
        "involves": [
          "solution-design-architect"
        ]
      },
      {
        "name": "implementation",
        "goal": "The change is implemented and assessed.",
        "involves": [
          "application-delivery-engineer",
          "delivery-quality-assessor",
          "security-risk-assessor"
        ]
      },
      {
        "name": "release-readiness",
        "goal": "Release packaging is complete.",
        "involves": [
          "change-release-manager"
        ]
      }
    ],
    "checkpoints": [
      {
        "name": "design-brief",
        "goal": "The design is ready.",
        "human_gate": false,
        "entry_criteria": "The request is authored."
      },
      {
        "name": "implementation",
        "goal": "The change is implemented and assessed.",
        "human_gate": false,
        "entry_criteria": "The design brief exists."
      },
      {
        "name": "release-readiness",
        "goal": "Release packaging is complete.",
        "human_gate": false,
        "entry_criteria": "All required assessments are approved."
      }
    ],
    "approval_rules": [],
    "handoff_rules": [
      {
        "from_role": "solution-design-architect",
        "to_role": "application-delivery-engineer",
        "required": true
      },
      {
        "from_role": "delivery-quality-assessor",
        "to_role": "change-release-manager",
        "required": true
      },
      {
        "from_role": "security-risk-assessor",
        "to_role": "change-release-manager",
        "required": true
      }
    ],
    "lifecycle": "planned",
    "orchestrator": {
      "max_rework_iterations": 5,
      "max_active_tasks": 4,
      "max_active_tasks_per_work_item": 3,
      "allow_parallel_work_items": false
    },
    "assessment_rules": [
      {
        "subject_role": "application-delivery-engineer",
        "assessed_by": "delivery-quality-assessor",
        "checkpoint": "implementation",
        "required": true,
        "outcome_actions": {
          "request_changes": {
            "action": "reopen_subject"
          },
          "rejected": {
            "action": "block_subject"
          }
        }
      },
      {
        "subject_role": "application-delivery-engineer",
        "assessed_by": "security-risk-assessor",
        "checkpoint": "implementation",
        "optional": true,
        "outcome_actions": {
          "request_changes": {
            "action": "escalate"
          },
          "rejected": {
            "action": "block_subject"
          }
        }
      }
    ]
  }
}
