{
  "name": "Content Block Subject Policy Pipeline",
  "slug": "live-test-content-block-subject-policy-v1",
  "description": "Content workflow with an explicit block_subject outcome action on rejection.",
  "outcome": "A rejected assessment leaves the workflow active and blocks the current subject work item.",
  "lifecycle": "planned",
  "definition": {
    "process_instructions": "The content strategist frames the change. The content author drafts it. The policy assessor evaluates the draft revision. When the draft violates a hard publishing rule, the rejected outcome MUST trigger the authored block_subject action and prevent successor packaging.",
    "parameters": [
      {
        "name": "goal",
        "type": "string",
        "required": true,
        "category": "input",
        "description": "What this live workflow should accomplish"
      }
    ],
    "roles": [
      "blockpolicy-content-strategist",
      "blockpolicy-content-author",
      "blockpolicy-quality-assessor",
      "blockpolicy-brand-assessor",
      "blockpolicy-publication-lead"
    ],
    "board": {
      "entry_column_id": "planned",
      "columns": [
        {
          "id": "planned",
          "label": "Planned",
          "description": "Work is defined but not yet assigned."
        },
        {
          "id": "active",
          "label": "In Progress",
          "description": "A specialist is actively working."
        },
        {
          "id": "blocked",
          "label": "Blocked",
          "description": "Work is blocked and needs intervention.",
          "is_blocked": true
        },
        {
          "id": "done",
          "label": "Done",
          "description": "The work item meets its acceptance criteria.",
          "is_terminal": true
        }
      ]
    },
    "stages": [
      {
        "name": "content-framing",
        "goal": "Design direction exists.",
        "involves": [
          "blockpolicy-content-strategist"
        ]
      },
      {
        "name": "draft-revision",
        "goal": "Draft revisions are assessed.",
        "involves": [
          "blockpolicy-content-author",
          "blockpolicy-quality-assessor"
        ]
      },
      {
        "name": "publication-packaging",
        "goal": "Release packaging is validated.",
        "involves": [
          "blockpolicy-publication-lead",
          "blockpolicy-quality-assessor"
        ]
      }
    ],
    "checkpoints": [
      {
        "name": "content-framing",
        "goal": "Design direction exists.",
        "human_gate": false,
        "entry_criteria": "The request is defined."
      },
      {
        "name": "draft-revision",
        "goal": "Implementation revisions are assessed.",
        "human_gate": false,
        "entry_criteria": "Architecture output is ready."
      },
      {
        "name": "publication-packaging",
        "goal": "Release packaging is validated.",
        "human_gate": false,
        "entry_criteria": "Active implementation revision is approved."
      }
    ],
    "approval_rules": [],
    "handoff_rules": [
      {
        "from_role": "blockpolicy-content-strategist",
        "to_role": "blockpolicy-content-author",
        "required": true
      },
      {
        "from_role": "blockpolicy-quality-assessor",
        "to_role": "blockpolicy-publication-lead",
        "required": true
      }
    ],
    "lifecycle": "planned",
    "orchestrator": {
      "max_rework_iterations": 5,
      "max_active_tasks": 4,
      "max_active_tasks_per_work_item": 2,
      "allow_parallel_work_items": false
    },
    "assessment_rules": [
      {
        "subject_role": "blockpolicy-content-author",
        "assessed_by": "blockpolicy-quality-assessor",
        "checkpoint": "draft-revision",
        "required": true,
        "decision_states": [
          "approved",
          "rejected"
        ],
        "outcome_actions": {
          "rejected": {
            "action": "block_subject"
          }
        }
      }
    ]
  }
}
