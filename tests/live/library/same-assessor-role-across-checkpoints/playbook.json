{
  "name": "Same Assessor Role Across Checkpoints Pipeline",
  "slug": "live-test-same-assessor-role-across-checkpoints-v1",
  "description": "Workflow where the same assessor role is required in multiple checkpoints.",
  "outcome": "The same assessor role can legally assess different subjects at more than one checkpoint.",
  "lifecycle": "planned",
  "definition": {
    "process_instructions": "The checkpoint reuse assessor evaluates both implementation and release-readiness output at different checkpoints. The system must preserve those as distinct, revision-aware assessment tasks.",
    "parameters": [
      {
        "name": "goal",
        "type": "string",
        "required": true,
        "category": "input",
        "description": "What this live workflow should accomplish"
      }
    ],
    "roles": [
      "checkpoint-reuse-framer",
      "checkpoint-reuse-implementer",
      "checkpoint-reuse-assessor",
      "checkpoint-reuse-integration-assessor",
      "checkpoint-reuse-release-coordinator"
    ],
    "board": {
      "entry_column_id": "planned",
      "columns": [
        {
          "id": "planned",
          "label": "Planned",
          "description": "Work is defined but not yet assigned."
        },
        {
          "id": "active",
          "label": "In Progress",
          "description": "A specialist is actively working."
        },
        {
          "id": "blocked",
          "label": "Blocked",
          "description": "Work is blocked and needs intervention.",
          "is_blocked": true
        },
        {
          "id": "done",
          "label": "Done",
          "description": "The work item meets its acceptance criteria.",
          "is_terminal": true
        }
      ]
    },
    "stages": [
      {
        "name": "architecture-pass",
        "goal": "Design direction exists.",
        "involves": [
          "checkpoint-reuse-framer"
        ]
      },
      {
        "name": "implementation-pass",
        "goal": "Implementation revisions are assessed.",
        "involves": [
          "checkpoint-reuse-implementer",
          "checkpoint-reuse-assessor",
          "checkpoint-reuse-integration-assessor"
        ]
      },
      {
        "name": "release-pass",
        "goal": "Release packaging is validated.",
        "involves": [
          "checkpoint-reuse-release-coordinator",
          "checkpoint-reuse-assessor"
        ]
      }
    ],
    "checkpoints": [
      {
        "name": "architecture-pass",
        "goal": "Design direction exists.",
        "human_gate": false,
        "entry_criteria": "The request is defined."
      },
      {
        "name": "implementation-pass",
        "goal": "Implementation revisions are assessed.",
        "human_gate": false,
        "entry_criteria": "Architecture output is ready."
      },
      {
        "name": "release-pass",
        "goal": "Release packaging is validated.",
        "human_gate": false,
        "entry_criteria": "Active implementation revision is approved."
      }
    ],
    "approval_rules": [],
    "handoff_rules": [
      {
        "from_role": "checkpoint-reuse-framer",
        "to_role": "checkpoint-reuse-implementer",
        "required": true
      },
      {
        "from_role": "checkpoint-reuse-assessor",
        "to_role": "checkpoint-reuse-release-coordinator",
        "required": true
      }
    ],
    "lifecycle": "planned",
    "orchestrator": {
      "max_rework_iterations": 5,
      "max_active_tasks": 4,
      "max_active_tasks_per_work_item": 2,
      "allow_parallel_work_items": false
    },
    "assessment_rules": [
      {
        "subject_role": "checkpoint-reuse-implementer",
        "assessed_by": "checkpoint-reuse-assessor",
        "checkpoint": "implementation-pass",
        "required": true,
        "outcome_actions": {
          "request_changes": {
            "action": "reopen_subject"
          },
          "rejected": {
            "action": "route_to_role",
            "role": "checkpoint-reuse-framer"
          }
        }
      },
      {
        "subject_role": "checkpoint-reuse-implementer",
        "assessed_by": "checkpoint-reuse-integration-assessor",
        "checkpoint": "implementation-pass",
        "required": true,
        "outcome_actions": {
          "request_changes": {
            "action": "escalate"
          },
          "rejected": {
            "action": "block_subject"
          }
        }
      },
      {
        "subject_role": "checkpoint-reuse-release-coordinator",
        "assessed_by": "checkpoint-reuse-assessor",
        "checkpoint": "release-pass",
        "required": true,
        "outcome_actions": {
          "request_changes": {
            "action": "reopen_subject"
          },
          "rejected": {
            "action": "block_subject"
          }
        }
      }
    ]
  }
}
