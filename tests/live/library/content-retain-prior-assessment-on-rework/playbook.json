{
  "name": "Content Retained Assessment Rework Pipeline",
  "slug": "live-test-content-retain-prior-assessment-on-rework-v1",
  "description": "Delivery pipeline that retains advisory assessments across subject revisions while refreshing required approvals.",
  "outcome": "Rework produces a new revision, keeps designated advisory assessments, and still requires the primary approval to be refreshed.",
  "lifecycle": "planned",
  "definition": {
    "process_instructions": "The platform architect defines the change. The feature engineer implements it. The primary quality assessor must reassess every new revision. The advisory assessor provides non-material guidance that MAY be retained across revisions according to authored retention policy.",
    "parameters": [
      {
        "name": "goal",
        "type": "string",
        "required": true,
        "category": "input",
        "description": "What this live workflow should accomplish"
      }
    ],
    "roles": [
      "retained-platform-architect",
      "retained-feature-engineer",
      "retained-quality-assessor",
      "retained-advisory-assessor",
      "retained-release-coordinator"
    ],
    "board": {
      "entry_column_id": "planned",
      "columns": [
        {
          "id": "planned",
          "label": "Planned",
          "description": "Work is defined but not yet assigned."
        },
        {
          "id": "active",
          "label": "In Progress",
          "description": "A specialist is actively working."
        },
        {
          "id": "blocked",
          "label": "Blocked",
          "description": "Work is blocked and needs intervention.",
          "is_blocked": true
        },
        {
          "id": "done",
          "label": "Done",
          "description": "The work item meets its acceptance criteria.",
          "is_terminal": true
        }
      ]
    },
    "stages": [
      {
        "name": "architecture-pass",
        "goal": "Design direction exists.",
        "involves": [
          "retained-platform-architect"
        ]
      },
      {
        "name": "implementation-pass",
        "goal": "Implementation revisions are assessed.",
        "involves": [
          "retained-feature-engineer",
          "retained-quality-assessor",
          "retained-advisory-assessor"
        ]
      },
      {
        "name": "release-pass",
        "goal": "Release packaging is validated.",
        "involves": [
          "retained-release-coordinator",
          "retained-quality-assessor"
        ]
      }
    ],
    "checkpoints": [
      {
        "name": "architecture-pass",
        "goal": "Design direction exists.",
        "human_gate": false,
        "entry_criteria": "The request is defined."
      },
      {
        "name": "implementation-pass",
        "goal": "Implementation revisions are assessed.",
        "human_gate": false,
        "entry_criteria": "Architecture output is ready."
      },
      {
        "name": "release-pass",
        "goal": "Release packaging is validated.",
        "human_gate": false,
        "entry_criteria": "Active implementation revision is approved."
      }
    ],
    "approval_rules": [],
    "handoff_rules": [
      {
        "from_role": "retained-platform-architect",
        "to_role": "retained-feature-engineer",
        "required": true
      },
      {
        "from_role": "retained-quality-assessor",
        "to_role": "retained-release-coordinator",
        "required": true
      }
    ],
    "lifecycle": "planned",
    "orchestrator": {
      "max_rework_iterations": 5,
      "max_active_tasks": 4,
      "max_active_tasks_per_work_item": 2,
      "allow_parallel_work_items": false
    },
    "assessment_rules": [
      {
        "subject_role": "retained-feature-engineer",
        "assessed_by": "retained-quality-assessor",
        "checkpoint": "implementation-pass",
        "required": true,
        "outcome_actions": {
          "request_changes": {
            "action": "reopen_subject"
          },
          "rejected": {
            "action": "route_to_role",
            "role": "retained-platform-architect"
          }
        }
      },
      {
        "subject_role": "retained-feature-engineer",
        "assessed_by": "retained-advisory-assessor",
        "checkpoint": "implementation-pass",
        "optional": true,
        "materiality": "non_material",
        "decision_states": [
          "approved"
        ],
        "revision_policy": {
          "assessment_retention": "retain_non_material_only"
        }
      },
      {
        "subject_role": "retained-release-coordinator",
        "assessed_by": "retained-quality-assessor",
        "checkpoint": "release-pass",
        "required": true,
        "outcome_actions": {
          "request_changes": {
            "action": "reopen_subject"
          },
          "rejected": {
            "action": "block_subject"
          }
        }
      }
    ]
  }
}
