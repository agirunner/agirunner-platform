[
  {
    "name": "Exa MCP",
    "description": "Remote Exa MCP server for search and crawling.",
    "endpointUrl": "https://mcp.exa.ai/mcp",
    "callTimeoutSeconds": 300,
    "authMode": "parameterized",
    "enabledByDefaultForNewSpecialists": false,
    "grantToAllExistingSpecialists": false,
    "parameters": [
      {
        "placement": "query",
        "key": "exaApiKey",
        "valueKind": "secret",
        "value": {
          "env": "LIVE_TEST_EXA_API_KEY"
        }
      }
    ]
  }
]
