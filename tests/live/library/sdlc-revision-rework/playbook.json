{
  "name": "SDLC Revision And Rework Pipeline",
  "slug": "live-test-sdlc-revision-rework-v1",
  "description": "Software-delivery pipeline that exercises multiple rework cycles and revision-aware assessment invalidation.",
  "outcome": "Rework produces new subject revisions, invalidates stale assessments, and only the active revision may advance.",
  "lifecycle": "planned",
  "definition": {
    "process_instructions": "The platform architect defines the change. The feature engineer implements it. The integration quality assessor evaluates the implementation revision. The integration assessor evaluates downstream compatibility. Request_changes should reopen the subject, route_to_role may send work back to the platform architect for redesign, and stale older assessments must never clear a newer revision. The integration quality assessor is reused across checkpoints and must reassess later release-readiness output when the playbook calls for it.",
    "parameters": [
      {
        "name": "goal",
        "type": "string",
        "required": true,
        "category": "input",
        "description": "What this live workflow should accomplish"
      }
    ],
    "roles": [
      "platform-architect",
      "feature-engineer",
      "integration-quality-assessor",
      "integration-assessor",
      "revision-release-coordinator"
    ],
    "board": {
      "entry_column_id": "planned",
      "columns": [
        {
          "id": "planned",
          "label": "Planned",
          "description": "Work is defined but not yet assigned."
        },
        {
          "id": "active",
          "label": "In Progress",
          "description": "A specialist is actively working."
        },
        {
          "id": "blocked",
          "label": "Blocked",
          "description": "Work is blocked and needs intervention.",
          "is_blocked": true
        },
        {
          "id": "done",
          "label": "Done",
          "description": "The work item meets its acceptance criteria.",
          "is_terminal": true
        }
      ]
    },
    "stages": [
      {
        "name": "architecture-pass",
        "goal": "Design direction exists.",
        "involves": [
          "platform-architect"
        ]
      },
      {
        "name": "implementation-pass",
        "goal": "Implementation revisions are assessed.",
        "involves": [
          "feature-engineer",
          "integration-quality-assessor",
          "integration-assessor"
        ]
      },
      {
        "name": "release-pass",
        "goal": "Release packaging is validated.",
        "involves": [
          "revision-release-coordinator",
          "integration-quality-assessor"
        ]
      }
    ],
    "checkpoints": [
      {
        "name": "architecture-pass",
        "goal": "Design direction exists.",
        "human_gate": false,
        "entry_criteria": "The request is defined."
      },
      {
        "name": "implementation-pass",
        "goal": "Implementation revisions are assessed.",
        "human_gate": false,
        "entry_criteria": "Architecture output is ready."
      },
      {
        "name": "release-pass",
        "goal": "Release packaging is validated.",
        "human_gate": false,
        "entry_criteria": "Active implementation revision is approved."
      }
    ],
    "approval_rules": [],
    "handoff_rules": [
      {
        "from_role": "platform-architect",
        "to_role": "feature-engineer",
        "required": true
      },
      {
        "from_role": "integration-quality-assessor",
        "to_role": "revision-release-coordinator",
        "required": true
      }
    ],
    "lifecycle": "planned",
    "orchestrator": {
      "max_rework_iterations": 5,
      "max_active_tasks": 4,
      "max_active_tasks_per_work_item": 2,
      "allow_parallel_work_items": false
    },
    "assessment_rules": [
      {
        "subject_role": "feature-engineer",
        "assessed_by": "integration-quality-assessor",
        "checkpoint": "implementation-pass",
        "required": true,
        "outcome_actions": {
          "request_changes": {
            "action": "reopen_subject"
          },
          "rejected": {
            "action": "route_to_role",
            "role": "platform-architect"
          }
        }
      },
      {
        "subject_role": "feature-engineer",
        "assessed_by": "integration-assessor",
        "checkpoint": "implementation-pass",
        "required": true,
        "outcome_actions": {
          "request_changes": {
            "action": "escalate"
          },
          "rejected": {
            "action": "block_subject"
          }
        }
      },
      {
        "subject_role": "revision-release-coordinator",
        "assessed_by": "integration-quality-assessor",
        "checkpoint": "release-pass",
        "required": true,
        "outcome_actions": {
          "request_changes": {
            "action": "reopen_subject"
          },
          "rejected": {
            "action": "block_subject"
          }
        }
      }
    ]
  }
}
