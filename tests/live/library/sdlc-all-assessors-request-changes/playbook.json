{
  "name": "SDLC All Assessors Request Changes Pipeline",
  "slug": "live-test-sdlc-all-assessors-request-changes-v1",
  "description": "Software-delivery workflow where both assessors request changes before later approval.",
  "outcome": "Multiple required assessments can each demand rework on the same subject revision before eventual clearance.",
  "lifecycle": "planned",
  "definition": {
    "process_instructions": "The design lead frames the change. The delivery engineer implements it. Both assessors are expected to request changes on an early revision before the later revision clears and packaging proceeds.",
    "parameters": [
      {
        "name": "goal",
        "type": "string",
        "required": true,
        "category": "input",
        "description": "What this live workflow should accomplish"
      }
    ],
    "roles": [
      "all-request-architecture-lead",
      "all-request-delivery-engineer",
      "all-request-quality-assessor",
      "all-request-security-assessor",
      "all-request-release-manager"
    ],
    "board": {
      "entry_column_id": "planned",
      "columns": [
        {
          "id": "planned",
          "label": "Planned",
          "description": "Work is defined but not yet assigned."
        },
        {
          "id": "active",
          "label": "In Progress",
          "description": "A specialist is actively working."
        },
        {
          "id": "blocked",
          "label": "Blocked",
          "description": "Work is blocked and needs intervention.",
          "is_blocked": true
        },
        {
          "id": "done",
          "label": "Done",
          "description": "The work item meets its acceptance criteria.",
          "is_terminal": true
        }
      ]
    },
    "stages": [
      {
        "name": "design-brief",
        "goal": "The design is ready.",
        "involves": [
          "all-request-architecture-lead"
        ]
      },
      {
        "name": "implementation",
        "goal": "The change is implemented and assessed.",
        "involves": [
          "all-request-delivery-engineer",
          "all-request-quality-assessor",
          "all-request-security-assessor"
        ]
      },
      {
        "name": "release-readiness",
        "goal": "Release packaging is complete.",
        "involves": [
          "all-request-release-manager"
        ]
      }
    ],
    "checkpoints": [
      {
        "name": "design-brief",
        "goal": "The design is ready.",
        "human_gate": false,
        "entry_criteria": "The request is authored."
      },
      {
        "name": "implementation",
        "goal": "The change is implemented and assessed.",
        "human_gate": false,
        "entry_criteria": "The design brief exists."
      },
      {
        "name": "release-readiness",
        "goal": "Release packaging is complete.",
        "human_gate": false,
        "entry_criteria": "All required assessments are approved."
      }
    ],
    "approval_rules": [],
    "handoff_rules": [
      {
        "from_role": "all-request-architecture-lead",
        "to_role": "all-request-delivery-engineer",
        "required": true
      },
      {
        "from_role": "all-request-quality-assessor",
        "to_role": "all-request-release-manager",
        "required": true
      },
      {
        "from_role": "all-request-security-assessor",
        "to_role": "all-request-release-manager",
        "required": true
      }
    ],
    "lifecycle": "planned",
    "orchestrator": {
      "max_rework_iterations": 5,
      "max_active_tasks": 4,
      "max_active_tasks_per_work_item": 3,
      "allow_parallel_work_items": false
    },
    "assessment_rules": [
      {
        "subject_role": "all-request-delivery-engineer",
        "assessed_by": "all-request-quality-assessor",
        "checkpoint": "implementation",
        "required": true,
        "outcome_actions": {
          "request_changes": {
            "action": "reopen_subject"
          },
          "rejected": {
            "action": "block_subject"
          }
        }
      },
      {
        "subject_role": "all-request-delivery-engineer",
        "assessed_by": "all-request-security-assessor",
        "checkpoint": "implementation",
        "required": true,
        "outcome_actions": {
          "request_changes": {
            "action": "route_to_role",
            "role": "all-request-architecture-lead"
          },
          "rejected": {
            "action": "block_subject"
          }
        }
      }
    ]
  }
