{
  "name": "Content Stale Assessment After Rework Pipeline",
  "slug": "live-test-content-stale-assessment-arrives-after-rework-v1",
  "description": "Revision-aware content workflow that rejects stale assessments from older revisions.",
  "outcome": "Only the active subject revision may clear the workflow after rework.",
  "lifecycle": "planned",
  "definition": {
    "process_instructions": "The content strategist defines the work. The content author revises it over multiple drafts. Assessors may complete out of order, but stale older assessments must never clear the current draft revision.",
    "parameters": [
      {
        "name": "goal",
        "type": "string",
        "required": true,
        "category": "input",
        "description": "What this live workflow should accomplish"
      }
    ],
    "roles": [
      "stale-content-strategist",
      "stale-content-author",
      "stale-quality-assessor",
      "stale-policy-assessor",
      "stale-publication-lead"
    ],
    "board": {
      "entry_column_id": "planned",
      "columns": [
        {
          "id": "planned",
          "label": "Planned",
          "description": "Work is defined but not yet assigned."
        },
        {
          "id": "active",
          "label": "In Progress",
          "description": "A specialist is actively working."
        },
        {
          "id": "blocked",
          "label": "Blocked",
          "description": "Work is blocked and needs intervention.",
          "is_blocked": true
        },
        {
          "id": "done",
          "label": "Done",
          "description": "The work item meets its acceptance criteria.",
          "is_terminal": true
        }
      ]
    },
    "stages": [
      {
        "name": "concept-pass",
        "goal": "Design direction exists.",
        "involves": [
          "stale-content-strategist"
        ]
      },
      {
        "name": "draft-pass",
        "goal": "Implementation revisions are assessed.",
        "involves": [
          "stale-content-author",
          "stale-quality-assessor",
          "stale-policy-assessor"
        ]
      },
      {
        "name": "publish-pass",
        "goal": "Release packaging is validated.",
        "involves": [
          "stale-publication-lead",
          "stale-quality-assessor"
        ]
      }
    ],
    "checkpoints": [
      {
        "name": "concept-pass",
        "goal": "Design direction exists.",
        "human_gate": false,
        "entry_criteria": "The request is defined."
      },
      {
        "name": "draft-pass",
        "goal": "Implementation revisions are assessed.",
        "human_gate": false,
        "entry_criteria": "Architecture output is ready."
      },
      {
        "name": "publish-pass",
        "goal": "Release packaging is validated.",
        "human_gate": false,
        "entry_criteria": "Active implementation revision is approved."
      }
    ],
    "approval_rules": [],
    "handoff_rules": [
      {
        "from_role": "stale-content-strategist",
        "to_role": "stale-content-author",
        "required": true
      },
      {
        "from_role": "stale-quality-assessor",
        "to_role": "stale-publication-lead",
        "required": true
      }
    ],
    "lifecycle": "planned",
    "orchestrator": {
      "max_rework_iterations": 5,
      "max_active_tasks": 4,
      "max_active_tasks_per_work_item": 2,
      "allow_parallel_work_items": false
    },
    "assessment_rules": [
      {
        "subject_role": "stale-content-author",
        "assessed_by": "stale-quality-assessor",
        "checkpoint": "draft-pass",
        "required": true,
        "outcome_actions": {
          "request_changes": {
            "action": "reopen_subject"
          },
          "rejected": {
            "action": "route_to_role",
            "role": "stale-content-strategist"
          }
        }
      },
      {
        "subject_role": "stale-content-author",
        "assessed_by": "stale-policy-assessor",
        "checkpoint": "draft-pass",
        "required": true,
        "outcome_actions": {
          "request_changes": {
            "action": "escalate"
          },
          "rejected": {
            "action": "block_subject"
          }
        }
      },
      {
        "subject_role": "stale-publication-lead",
        "assessed_by": "stale-quality-assessor",
        "checkpoint": "publish-pass",
        "required": true,
        "outcome_actions": {
          "request_changes": {
            "action": "reopen_subject"
          },
          "rejected": {
            "action": "block_subject"
          }
        }
      }
    ]
  }
}
