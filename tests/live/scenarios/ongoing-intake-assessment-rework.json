{
  "name": "ongoing-intake-assessment-rework",
  "profile": "ongoing-intake-assessment",
  "workflow": {
    "name": "Ongoing Intake Assessment Rework",
    "goal": "Run an ongoing intake workflow where multiple items are reopened by assessment and the workflow returns to pending when idle.",
    "parameters": {
      "intake_contract": "At least one intake item should request changes before a corrected resubmission is approved."
    }
  },
  "workspace": {
    "repo": false,
    "memory": {
      "program": "ongoing intake"
    },
    "spec": {}
  },
  "approvals": [],
  "actions": [
    {
      "type": "create_work_items",
      "dispatch": "parallel",
      "count": 2,
      "title_template": "intake-wave-{index:02d}",
      "request_id_template": "intake-wave-{index:02d}"
    }
  ],
  "expect": {
    "state": "pending",
    "workflow_fields": {
      "lifecycle": "ongoing"
    },
    "work_items": {
      "min_count": 2,
      "all_terminal": true
    },
    "workflow_tasks": {
      "min_non_orchestrator_count": 4
    },
    "continuity_rework_sequences": [
      {
        "stage_name": "intake-triage",
        "required_role": "intake-analyst",
        "minimum_rework_count": 1,
        "assessment_stage_name": "intake-triage",
        "assessment_task_min_count": 2
      }
    ]
  },
  "coverage": {
    "playbook_shapes": [
      "one_checkpoint"
    ],
    "concurrency": [
      "multiple_active_subjects_same_workflow"
    ],
    "subject_revisions": [
      "one_rework"
    ],
    "storage_execution": [
      "memory_heavy"
    ]
  }
}
