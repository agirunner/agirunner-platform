{
  "name": "host-directory-content-assessment",
  "profile": "host-directory-assessment",
  "workflow": {
    "name": "Host Directory Content Assessment",
    "goal": "Fix and assess host-mounted documentation content without a repository remote.",
    "parameters": {
      "maintenance_contract": "The assessor should request one real correction if the first host-directory change misses the authored acceptance bar."
    }
  },
  "workspace": {
    "repo": false,
    "storage": {
      "type": "host_directory"
    },
    "memory": {
      "workspace_kind": "host-directory"
    },
    "spec": {}
  },
  "approvals": [],
  "actions": [],
  "expect": {
    "state": "completed",
    "host_files": [
      {
        "path": "README.md"
      }
    ],
    "outcome_envelope": {
      "allowed_states": [
        "completed"
      ],
      "require_output_artifacts": true,
      "require_completed_non_orchestrator_tasks": true,
      "require_terminal_work_items": true,
      "require_db_state": true,
      "require_runtime_cleanup": true,
      "require_fatal_log_free": true
    }
  },
  "coverage": {
    "storage_execution": [
      "host_directory_workspace"
    ]
  }
}
