{
  "name": "runtime-task-sandbox-split",
  "profile": "runtime-task-sandbox-split",
  "workflow": {
    "name": "Runtime Task Sandbox Split",
    "goal": "Extend the seeded Python CLI with a deterministic `status-report` command, prove that planning and release-summary work run through runtime-owned tools, and prove that repository mutation plus artifact upload run through a specialist task sandbox.",
    "parameters": {
      "scenario_name": "runtime-task-sandbox-split"
    }
  },
  "workspace": {
    "repo": true,
    "memory": {},
    "spec": {
      "instructions": {
        "content": "This workspace already contains a seeded Python standard-library CLI scaffold. The workflow MUST stay prose-driven: planning, implementation, then release summary. The planning analyst MUST work only through runtime-owned tools and MUST write a concise memory note that names the exact command, verification path, and artifact path the implementation engineer will deliver. The implementation engineer MUST add `python3 -m workflow_cli status-report --scenario-name <name>` so it emits deterministic JSON with `scenario_name`, `service`, `status`, and `release_summary_artifact` fields, MUST update tests so `./scripts/verify.sh` proves that command, MUST create `reports/runtime-task-sandbox-summary.md`, and MUST upload that file as a task artifact. The release coordinator MUST work only through runtime-owned tools, MUST read the uploaded artifact through artifact read tools rather than repository tools, MUST persist a final release-summary memory note, and MUST submit one structured handoff.",
        "format": "markdown"
      }
    }
  },
  "approvals": [],
  "actions": [],
  "expect": {
    "state": "completed",
    "workflow_tasks": {
      "min_non_orchestrator_count": 3,
      "forbid_task_kinds": [
        "assessment",
        "approval"
      ]
    },
    "direct_handoff_expectations": [
      {
        "source_role": "runtime-split-planning-analyst",
        "successor_role": "runtime-split-implementation-engineer"
      },
      {
        "source_role": "runtime-split-implementation-engineer",
        "successor_role": "runtime-split-release-coordinator"
      }
    ],
    "task_backend_expectations": [
      {
        "match": {
          "is_orchestrator_task": true
        },
        "execution_backend": "runtime_only",
        "used_task_sandbox": false,
        "min_count": 2
      },
      {
        "match": {
          "role": "runtime-split-planning-analyst"
        },
        "execution_backend": "runtime_plus_task",
        "used_task_sandbox": false,
        "min_count": 1
      },
      {
        "match": {
          "role": "runtime-split-implementation-engineer"
        },
        "execution_backend": "runtime_plus_task",
        "used_task_sandbox": true,
        "min_count": 1
      },
      {
        "match": {
          "role": "runtime-split-release-coordinator"
        },
        "execution_backend": "runtime_plus_task",
        "used_task_sandbox": false,
        "min_count": 1
      }
    ],
    "log_row_expectations": [
      {
        "match": {
          "operation": "tool.execute",
          "status": "completed",
          "execution_backend": "runtime_plus_task",
          "tool_owner": "runtime",
          "payload": {
            "tool_name": "memory_write"
          }
        },
        "min_count": 2
      },
      {
        "match": {
          "operation": "tool.execute",
          "status": "completed",
          "execution_backend": "runtime_plus_task",
          "tool_owner": "runtime",
          "payload": {
            "tool_name": "artifact_read"
          }
        },
        "min_count": 1
      },
      {
        "match": {
          "operation": "tool.execute",
          "status": "completed",
          "execution_backend": "runtime_plus_task",
          "tool_owner": "task",
          "payload": {
            "tool_name": "artifact_upload"
          }
        },
        "min_count": 1
      }
    ],
    "container_observation_expectations": [
      {
        "match": {
          "kind": "orchestrator",
          "execution_backend": "runtime_only"
        },
        "min_count": 1
      },
      {
        "match": {
          "kind": "runtime",
          "execution_backend": "runtime_plus_task"
        },
        "min_count": 1
      },
      {
        "match": {
          "kind": "task",
          "execution_backend": "runtime_plus_task"
        },
        "min_count": 1
      }
    ],
    "evidence_expectations": {
      "db_state_present": true,
      "runtime_cleanup_passed": true,
      "docker_log_rotation_passed": true,
      "log_anomalies_empty": true
    },
    "work_items": {
      "all_terminal": true
    }
  },
  "coverage": {
    "delivery_paths": [
      "direct_successor"
    ],
    "assessor_cardinality": [
      "zero"
    ],
    "successor_gating": [
      "direct_after_handoff"
    ],
    "playbook_shapes": [
      "custom_role_names",
      "multi_stage"
    ],
    "storage_execution": [
      "git_workspace",
      "mixed_git_memory_artifacts",
      "cold_specialists",
      "warm_orchestrators"
    ]
  },
  "poll_interval_seconds": 1
}
