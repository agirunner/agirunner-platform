{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agirunner.dev/schemas/test-batch/stage-report.v1.json",
  "title": "Agirunner Batch Stage Report v1",
  "type": "object",
  "required": [
    "version",
    "runId",
    "stageId",
    "stageLabel",
    "status",
    "command",
    "startedAt",
    "finishedAt",
    "durationMs",
    "logs",
    "artifacts"
  ],
  "properties": {
    "version": { "const": "1.0" },
    "runId": { "type": "string", "minLength": 1 },
    "stageId": { "type": "string", "minLength": 1 },
    "stageLabel": { "type": "string", "minLength": 1 },
    "lane": { "type": "string", "minLength": 1 },
    "provider": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["sequential", "parallel"] },
    "status": { "enum": ["pass", "fail", "infra-fail", "skipped"] },
    "failurePolicy": { "enum": ["fail-fast", "continue-on-error"] },
    "command": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "startedAt": { "type": "string", "format": "date-time" },
    "finishedAt": { "type": "string", "format": "date-time" },
    "durationMs": { "type": "integer", "minimum": 0 },
    "exitCode": { "type": "integer", "minimum": 0 },
    "errorExcerpt": { "type": "string" },
    "notRunReason": { "type": "string" },
    "ports": {
      "type": "object",
      "properties": {
        "postgres": { "type": "integer", "minimum": 1 },
        "platformApi": { "type": "integer", "minimum": 1 },
        "dashboard": { "type": "integer", "minimum": 1 }
      },
      "additionalProperties": false
    },
    "composeProjectName": { "type": "string" },
    "logs": {
      "type": "object",
      "required": ["stdout", "stderr"],
      "properties": {
        "stdout": { "type": "string", "minLength": 1 },
        "stderr": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "artifacts": {
      "type": "object",
      "required": ["laneArtifactsRoot", "laneResultsPath"],
      "properties": {
        "laneArtifactsRoot": { "type": "string", "minLength": 1 },
        "laneResultsPath": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
