{
  "version": "1.0",
  "defaultMode": "sequential",
  "defaultFailurePolicy": "continue-on-error",
  "defaultProviders": ["openai"],
  "reportRoot": "tests/artifacts/batch",
  "parallel": {
    "maxConcurrency": 3
  },
  "ports": {
    "postgresBase": 5540,
    "platformApiBase": 8140,
    "dashboardBase": 3140
  },
  "compose": {
    "projectPrefix": "agirunner-batch"
  },
  "stages": {
    "unit": {
      "label": "Unit + harness guard tests",
      "command": ["pnpm", "test"],
      "docker": false
    },
    "core": {
      "label": "E2E core lane",
      "command": ["pnpm", "test:core:all"],
      "docker": true
    },
    "integrationDashboard": {
      "label": "E2E integration/dashboard lane",
      "command": ["pnpm", "exec", "tsx", "tests/live/harness/runner.ts", "--dashboard"],
      "docker": true
    },
    "live": {
      "label": "E2E live lane",
      "command": [
        "pnpm",
        "exec",
        "tsx",
        "tests/live/harness/runner.ts",
        "--lane",
        "live",
        "--provider",
        "__PROVIDER__",
        "--all"
      ],
      "docker": true
    }
  }
}
