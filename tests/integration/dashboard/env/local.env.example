# This suite reads repo-root .env or exported env vars.
# Mirror the values you need into .env before running:
#   bash tests/integration/dashboard/run.sh

DEFAULT_ADMIN_API_KEY=replace-with-at-least-20-characters
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_DB=agirunner
POSTGRES_USER=agirunner
POSTGRES_PASSWORD=agirunner
PLATFORM_API_PORT=8080
DASHBOARD_PORT=3000
ARTIFACT_LOCAL_ROOT=tmp/integration-artifacts

# Default local-stack mode keeps the existing platform stack outside Playwright.
# Set to 0 only when you intentionally want the Playwright-managed stack path.
# PLAYWRIGHT_SKIP_WEBSERVER=1
